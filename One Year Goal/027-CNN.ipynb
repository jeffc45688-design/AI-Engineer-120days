    "import torch \n",
    "import torch.nn as nn\n",
    "X=torch.randn(1,1,5,5)\n",
    "conv=nn.Conv2d(\n",
    "        in_channels=1,\n",
    "        out_channels=2,\n",
    "        kernel_size=3\n",
    ")\n",
    "y=conv(X)\n",
    "print(\"input shape\",X.shape)\n",
    "print(\"output shape\",y.shape)\n",
    "print(y)\n"
   ]
  }
