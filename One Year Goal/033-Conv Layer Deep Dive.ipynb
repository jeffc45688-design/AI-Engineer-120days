    "\n",
    "import torch  \n",
    "import torch.nn as nn\n",
    "X=torch.randn(1,1,28,28)\n",
    "conv=nn.Conv2d(\n",
    "    in_channels=1,\n",
    "    out_channels=8,\n",
    "    kernel_size=3,\n",
    "    stride=1,\n",
    "    padding=0\n",
    ")\n",
    "Y=conv(X)\n",
    "print(Y.shape)\n",
    "print(X.shape)"
   ]
  }
