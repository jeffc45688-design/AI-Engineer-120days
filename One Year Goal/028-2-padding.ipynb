   "source": [
    "import torch \n",
    "import torch.nn as nn\n",
    "X=torch.randn(1,1,6,6)\n",
    "conv=nn.Conv2d(1,2,3,padding=1)#output=(input+2*padding-kernel)/stride+1  #padding保持圖片大小 避免裁切後越來越小\n",
    "y=conv(X)\n",
    "print(X.shape)\n",
    "print(y.shape)"
   ]
  }
